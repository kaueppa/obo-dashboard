# ================================================================
# Obo Dashboard — Variáveis de Ambiente
# Copie este arquivo para .env.local para desenvolvimento local
# No Vercel: adicione cada variável em Settings → Environment Variables
# ================================================================

# ─── TRELLO ──────────────────────────────────────────────────
# Obtenha em: https://trello.com/app-key
TRELLO_API_KEY=sua_api_key_aqui
TRELLO_TOKEN=seu_token_aqui
TRELLO_BOARD_ID=o2sztgqv

# ─── CLICKUP ─────────────────────────────────────────────────
# Obtenha em: ClickUp → Settings → Apps → API Token
CLICKUP_TOKEN=seu_personal_token_aqui
CLICKUP_LIST_ID=901311064373

# ─── CONTA AZUL PRO ──────────────────────────────────────────
# Obtenha em: app.contaazul.com → Configurações → API → Aplicações
# Siga o fluxo OAuth2 para gerar o refresh_token (ver instruções no README)
CONTAAZUL_CLIENT_ID=seu_client_id_aqui
CONTAAZUL_CLIENT_SECRET=seu_client_secret_aqui
CONTAAZUL_REFRESH_TOKEN=seu_refresh_token_aqui

# ─── BANCO INTER PJ ──────────────────────────────────────────
# Obtenha em: Inter → Empresas → Mais → API Banking → Minhas Aplicações
# Requer geração de certificado digital mTLS (.crt + .key)
# Cole o conteúdo do certificado em base64 (cat cert.crt | base64)
INTER_CLIENT_ID=seu_client_id_aqui
INTER_CLIENT_SECRET=seu_client_secret_aqui
INTER_CERT_PEM=conteudo_base64_do_certificado_crt
INTER_KEY_PEM=conteudo_base64_da_chave_key
